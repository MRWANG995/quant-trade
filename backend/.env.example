# 复制为 backend/.env：cp .env.example .env

DATABASE_URL=sqlite+aiosqlite:///./quant_trade.db
# DATABASE_URL=postgresql+asyncpg://quant:quant@localhost:5432/quant_trade

BROKER_MODE=paper
MAX_TRADES_PER_DAY=2
MAX_TRADES_PER_SYMBOL_PER_DAY=1
INITIAL_CAPITAL=100000
FAST_MA=20
SLOW_MA=50
DAILY_RUN_CRON=0 22 * * 1-5

YFINANCE_SYNC_ON_DAILY=false
YFINANCE_STALE_DAYS=2
YFINANCE_MAX_RETRIES=2
YFINANCE_RETRY_BASE_SECONDS=5.0
YFINANCE_REQUEST_DELAY_SECONDS=5.0

STOOQ_API_KEY=
ALPHAVANTAGE_API_KEY=
# 无 Key 时黄金/期货拉取失败后自动演示补全（默认 true，无需 Stooq）
AUTO_DEMO_FALLBACK=true

IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1
IB_ACCOUNT=

OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice

# 认证（生产务必修改）
SECRET_KEY=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080
REQUIRE_AUTH=false
ALLOW_REGISTRATION=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

# LLM 对话生成策略（默认 Google Gemini 2.0 Flash，免费层 15 RPM / 1500 RPD）
# 申请 Key：https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Sharpe 计算的无风险利率兜底（年化小数，FRED 拉取失败时用）
DEFAULT_RISK_FREE_RATE=0.0
